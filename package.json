{
  "name": "corinthians-study-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PATH=./bin:$PATH NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "build": "PATH=./bin:$PATH NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next build --webpack",
    "start": "PATH=./bin:$PATH next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:background": "node scripts/validate-background.mjs",
    "validate:corinthians": "node scripts/validate-corinthians-content.mjs",
    "validate:theology": "node scripts/validate-corinthians-theology.mjs",
    "validate:humanization": "node scripts/validate-corinthians-humanization.mjs",
    "validate:library": "python3 scripts/validate-corinthians-library.py",
    "build:sdabc-map": "python3 scripts/build-sdabc-verse-map.py",
    "build:sdabc-matrix": "python3 scripts/build-sdabc-alignment-matrix.py",
    "resolve:sdabc-matrix": "python3 scripts/resolve-sdabc-alignment.py",
    "validate:sdabc": "python3 scripts/validate-sdabc-alignment.py",
    "validate:sdabc:structure": "python3 scripts/validate-sdabc-alignment.py --allow-pending",
    "generate:reference-previews": "node scripts/generate-reference-previews.mjs",
    "import:corinthians-notes": "node scripts/import-corinthians-notes.mjs",
    "audit:corinthians-copying": "python3 scripts/audit-corinthians-copying.py"
  },
  "dependencies": {
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^16.2.6",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.5.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "latest"
  }
}
